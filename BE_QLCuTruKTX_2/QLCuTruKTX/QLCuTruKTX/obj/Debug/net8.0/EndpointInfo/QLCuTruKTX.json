            "type": "string",
            "nullable": true
          },
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time"
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "className": {
            "type": "string",
            "nullable": true
          },
          "faculty": {
            "type": "string",
            "nullable": true
          },
          "idCard": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Form": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "sinhVienId": {
            "type": "integer",
            "format": "int32"
          },
          "student": {
            "$ref": "#/components/schemas/Student"
          },
          "loaiDon": {
            "type": "string",
            "nullable": true
          },
          "diaDiem": {
            "type": "string",
            "nullable": true
          },
          "ngayBatDau": {
            "type": "string",
            "format": "date-time"
          },
          "ngayKetThuc": {
            "type": "string",
            "format": "date-time"
          },
          "lyDo": {
            "type": "string",
            "nullable": true
          },
          "trangThai": {
            "type": "string",
            "nullable": true
          },
          "ngayTao": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
